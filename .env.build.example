# Build-time Environment Variables (Placeholders Only)
#
# ⚠️ IMPORTANT: These values are embedded in the build bundle.
# However, they are OVERRIDDEN by config.json at runtime.
#
# For production builds, use PLACEHOLDER values here since:
# 1. They will be replaced by config.json at runtime
# 2. They serve only as a fallback if config.json is missing
# 3. Using real values here would expose them in the JavaScript bundle
#
# Copy this to .env.build and use it for builds:
#   cp .env.build.example .env.build
#   npm run build:safe
#   OR
#   npm run release -- 1.0.24

# API Key (placeholder - will be overridden by config.json)
VITE_API_KEY=placeholder-api-key-do-not-use-in-production

# URLs para HTTP (placeholders - will be overridden by config.json)
VITE_URL_API_HTTP=http://placeholder-api.com:8084
VITE_URL_ACCESS_CONTROL_HTTP=http://placeholder-api.com:8084

# URLs para HTTPS (placeholders - will be overridden by config.json)
VITE_URL_API_HTTPS=https://placeholder-api.com:8094
VITE_URL_ACCESS_CONTROL_HTTPS=https://placeholder-api.com:8094

# URLs do Updater (placeholders - will be overridden by config.json)
VITE_UPDATER_API_URL_HTTP=http://placeholder-updater.com:5275
VITE_UPDATER_API_URL_HTTPS=https://placeholder-updater.com:7038

# Chave do Updater (placeholder - will be overridden by config.json)
VITE_UPDATER_API_KEY=placeholder-updater-key

# Identificador do Cliente (placeholder - will be overridden by config.json)
VITE_CLIENT_KEY=00000000-0000-0000-0000-000000000000

# ID da Licença (placeholder - will be overridden by config.json)
VITE_LICENCA_ID=

# Encryption Key (placeholder - will be overridden by config.json)
VITE_ENCRYPTION_KEY=placeholder-encryption-key-change-in-production
